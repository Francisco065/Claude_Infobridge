# ============================================================
#  INFOBRIDGE — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores.
#  NUNCA versione o .env real no Git.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=infobridge
POSTGRES_USER=infobridge
POSTGRES_PASSWORD=TROCAR_SENHA_SEGURA

# String de conexão completa (usada pelo NestJS e pelo Worker Python)
DATABASE_URL=postgresql://infobridge:TROCAR_SENHA_SEGURA@db:5432/infobridge

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=TROCAR_SENHA_REDIS
REDIS_URL=redis://:TROCAR_SENHA_REDIS@redis:6379/0

# ── NestJS / API ────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROCAR_SECRET_JWT_64_BYTES_HEX
JWT_EXPIRATION=8h
JWT_REFRESH_EXPIRATION=7d

# ── Criptografia de senhas (AES-256) ────────────────────────
# Chave para criptografar as senhas da Multiportal em credencial_integracao
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=TROCAR_CHAVE_AES_32_BYTES_HEX

# ── Worker Python ───────────────────────────────────────────
WORKER_API_PORT=8000

# Celery
CELERY_BROKER_URL=redis://:TROCAR_SENHA_REDIS@redis:6379/0
CELERY_RESULT_BACKEND=redis://:TROCAR_SENHA_REDIS@redis:6379/1

# ── Multiportal ─────────────────────────────────────────────
# URL base da API da Multiportal
MULTIPORTAL_BASE_URL=http://apiv1.multiportal.com.br:9870
# Intervalo de polling dos dados_novos (segundos) — mínimo recomendado: 120s
MULTIPORTAL_POLLING_INTERVAL=120

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error

# ── Claude API (geração de notas por LLM — opcional) ────────
ANTHROPIC_API_KEY=sk-ant-TROCAR_SE_FOR_USAR_LLM
